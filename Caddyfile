# HTTPS-Reverse-Proxy vor den OpenBuchhaltung-MCP-Server (Streamable HTTP).
#
# Zweck: Claude-Desktop-Custom-Connectoren benötigen eine per HTTPS mit gültigem
# Zertifikat erreichbare URL. Caddy terminiert TLS und leitet an den internen
# mcp-Service (Port 8090, Pfad /mcp) weiter.
#
# Voraussetzungen:
#   * Umgebungsvariable MCP_DOMAIN gesetzt (z. B. mcp.example.com) und ein
#     A/AAAA-DNS-Record, der auf diesen Server zeigt.
#   * Ports 80 und 443 des Servers aus dem Internet erreichbar (für die
#     ACME-Challenge und den späteren HTTPS-Zugriff).
#
# Start: docker compose --profile proxy up -d caddy
# Connector-URL in Claude Desktop: https://<MCP_DOMAIN>/mcp

{$MCP_DOMAIN} {
	reverse_proxy mcp:8090 {
		# Der MCP-Server prüft den Origin-Header (DNS-Rebinding-Schutz, gedacht für
		# direkten Browserzugriff). Hinter diesem vertrauenswürdigen Proxy entfernen
		# wir den Header, damit der Connector zuverlässig zugelassen wird.
		header_up -Origin
	}

	# --- Optionaler Zugriffsschutz -------------------------------------------
	# Der MCP-Endpunkt selbst hat KEINE Authentifizierung: Wer die URL erreicht,
	# kann Tools aufrufen (u. a. Buchungen anlegen). Beschränke den Zugriff daher
	# möglichst auf bekannte Client-IPs (die Maschine mit Claude Desktop) oder ein
	# VPN. Zum Aktivieren die beiden Zeilen entkommentieren und IPs anpassen:
	#
	# @erlaubt remote_ip 203.0.113.7 198.51.100.0/24
	# handle @erlaubt {
	# 	reverse_proxy mcp:8090 {
	# 		header_up -Origin
	# 	}
	# }
	# respond "Forbidden" 403
}
